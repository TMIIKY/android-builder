/* ========================================
   灵墨 AI小说生成器 - 移动端样式
   深色主题，卡片式设计，iOS/Android 风格
   ======================================== */

/* ===== 基础变量 ===== */
:root {
    --bg-primary: #0f0f1a;
    --bg-secondary: #1a1a2e;
    --bg-card: #1e1e36;
    --bg-card-hover: #252542;
    --bg-input: #252542;
    --text-primary: #e8e8f0;
    --text-secondary: #a0a0b8;
    --text-muted: #6b6b80;
    --accent: #6366f1;
    --accent-hover: #5558e6;
    --accent-light: rgba(99, 102, 241, 0.15);
    --success: #27ae60;
    --danger: #e74c3c;
    --warning: #f39c12;
    --border: #2a2a45;
    --border-light: #35355a;
    --shadow: 0 2px 12px rgba(0,0,0,0.3);
    --radius: 12px;
    --radius-sm: 8px;
    --radius-lg: 16px;
    --nav-height: 56px;
    --bottom-nav-height: 64px;
    --safe-bottom: env(safe-area-inset-bottom, 0px);
    --font-mono: 'SF Mono', 'Menlo', 'Consolas', monospace;
}

/* ===== 全局重置 ===== */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    height: 100%;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
}

#app {
    display: flex;
    flex-direction: column;
    height: 100vh;
    height: 100dvh;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
    overflow: visible;
}

/* ===== 顶部导航 ===== */
.top-nav {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    padding: 0 12px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    z-index: 100;
}

.nav-back, .nav-action {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-primary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.2s;
}

.nav-back:hover, .nav-action:hover {
    background: var(--bg-input);
}

.nav-title {
    flex: 1;
    text-align: center;
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.5px;
}

/* ===== 主内容区 ===== */
.main-content {
    flex: 1;
    overflow-y: auto;
    overflow-x: visible;
    padding-bottom: var(--bottom-nav-height);
    -webkit-overflow-scrolling: touch;
}

.page {
    display: none;
    padding: 16px;
    animation: fadeIn 0.25s ease;
}

.page.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ===== 书架页 ===== */
.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
}

.page-header h2 {
    font-size: 22px;
    font-weight: 700;
}

.book-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    padding-bottom: 80px;
}

.book-card {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 12px 44px 12px 12px;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid var(--border);
    position: relative;
    min-height: 76px;
}

.book-card:active {
    transform: scale(0.98);
    background: var(--bg-card-hover);
}

.book-cover {
    width: 46px;
    height: 60px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: 12px;
}

.book-cover-title {
    font-size: 14px;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
}

.book-card-info {
    flex: 1;
    min-width: 0;
    overflow: hidden;
}

.book-card-info h4 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.book-meta {
    font-size: 11px;
    color: var(--text-secondary);
    margin-bottom: 2px;
}

.book-desc-truncate {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.book-card-action {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(231, 76, 60, 0.15);
    border: none;
    color: var(--danger);
    border-radius: 6px;
    cursor: pointer;
    opacity: 1;
    font-size: 11px;
    font-weight: bold;
    transition: all 0.2s;
    z-index: 10;
}

.book-card-action:active {
    background: rgba(231, 76, 60, 0.4);
    color: var(--danger);
}

/* ===== 书籍详情页 ===== */
.book-info-header {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 16px;
    border: 1px solid var(--border);
}

.book-detail-info h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 6px;
}

.book-detail-meta {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.book-detail-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 12px;
    line-height: 1.6;
}

.book-detail-actions {
    display: flex;
    gap: 8px;
}

.chapter-toolbar {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
}

.chapter-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.chapter-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    cursor: pointer;
    border: 1px solid var(--border);
    transition: all 0.2s;
}

.chapter-item:active {
    background: var(--bg-card-hover);
}

.chapter-item-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
}

.chapter-order {
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-light);
    padding: 2px 8px;
    border-radius: 4px;
    flex-shrink: 0;
}

.chapter-item-title {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.chapter-type-badge {
    font-size: 10px;
    background: var(--accent-light);
    color: var(--accent);
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
}

.chapter-item-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
}

.chapter-word-count {
    font-size: 11px;
    color: var(--text-muted);
}

/* ===== 章节编辑页 ===== */
.chapter-edit-header {
    margin-bottom: 12px;
}

.chapter-title-input {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s;
}

.chapter-title-input:focus {
    border-color: var(--accent);
}

.chapter-title-input::placeholder {
    color: var(--text-muted);
    font-weight: 400;
}

.ai-generate-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
}

.prompt-input {
    flex: 1;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s;
}

.prompt-input:focus {
    border-color: var(--accent);
}

.prompt-input::placeholder {
    color: var(--text-muted);
}

.generation-options {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
}

.option-row {
    display: flex;
    align-items: center;
    gap: 6px;
}

.option-row label {
    font-size: 12px;
    color: var(--text-secondary);
    white-space: nowrap;
}

.option-row select {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
    color: var(--text-primary);
    outline: none;
}

.editor-container {
    margin-bottom: 12px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
}

.content-editor {
    width: 100%;
    min-height: calc(100vh - 380px);
    background: var(--bg-input);
    border: none;
    padding: 16px;
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.9;
    resize: none;
    outline: none;
    font-family: inherit;
}

.content-editor::placeholder {
    color: var(--text-muted);
}

.editor-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
}

/* ===== 设置页 ===== */
.settings-section {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 16px;
    margin-bottom: 16px;
    border: 1px solid var(--border);
}

.settings-section h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text-secondary);
}

.model-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 12px;
}

.model-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-input);
    border-radius: var(--radius-sm);
    padding: 12px;
    border: 1px solid var(--border);
}

.model-item.active {
    border-color: var(--accent);
    background: var(--accent-light);
}

.model-item-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
}

.model-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
}

.model-details {
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.model-details strong {
    font-size: 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.model-details span {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.model-item-actions {
    display: flex;
    gap: 4px;
}

.model-select {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
}

.about-text {
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.8;
}

/* ===== 数据备份管理 ===== */
.settings-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 12px;
}

.backup-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.backup-actions .btn-full {
    width: 100%;
    justify-content: center;
    gap: 6px;
}

/* 导出格式选择 */
.export-format-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.export-format-option {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s;
}

.export-format-option:hover {
    border-color: var(--accent);
}

.export-format-option input[type="radio"] {
    margin-top: 3px;
    accent-color: var(--accent);
}

.export-format-label {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.export-format-label strong {
    font-size: 14px;
    color: var(--text-primary);
}

.export-format-label small {
    font-size: 12px;
    color: var(--text-muted);
}

/* ===== 工作流页 ===== */
.workflow-header {
    text-align: center;
    margin-bottom: 20px;
}

.workflow-header h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 4px;
}

.workflow-header p {
    font-size: 13px;
    color: var(--text-secondary);
}

.workflow-modules {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.wf-module {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 16px;
    cursor: pointer;
    border: 1px solid var(--border);
    transition: all 0.2s;
    gap: 12px;
}

.wf-module:active {
    background: var(--bg-card-hover);
    transform: scale(0.98);
}

.wf-icon {
    font-size: 28px;
    flex-shrink: 0;
}

.wf-info {
    flex: 1;
}

.wf-info h4 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
}

.wf-info p {
    font-size: 12px;
    color: var(--text-secondary);
}

/* ===== 按钮样式 ===== */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
}

.btn:active {
    transform: scale(0.96);
}

.btn-primary {
    background: var(--accent);
    color: white;
}

.btn-primary:hover {
    background: var(--accent-hover);
}

.btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-outline {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-light);
}

.btn-outline:hover {
    background: var(--bg-input);
}

.btn-ai {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    font-weight: 600;
    padding: 10px 16px;
}

.btn-ai:disabled {
    opacity: 0.6;
}

.btn-sm {
    padding: 6px 14px;
    font-size: 13px;
}

.btn-full {
    width: 100%;
}

.btn-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-muted);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-icon:hover {
    background: var(--bg-input);
    color: var(--text-primary);
}

.btn-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
}

/* ===== 底部导航 ===== */
.bottom-nav {
    display: flex;
    align-items: center;
    justify-content: space-around;
    height: var(--bottom-nav-height);
    padding-bottom: var(--safe-bottom);
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    z-index: 100;
}

.bottom-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 6px 16px;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 11px;
    font-weight: 500;
}

.bottom-nav-item.active {
    color: var(--accent);
}

.bottom-nav-item svg {
    transition: all 0.2s;
}

.bottom-nav-item:active {
    transform: scale(0.9);
}

/* ===== 模态框 ===== */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
}

.modal-overlay.active {
    opacity: 1;
    pointer-events: all;
}

.modal {
    width: 100%;
    max-width: 480px;
    max-height: 85vh;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.modal-overlay.active .modal {
    transform: translateY(0);
}

.modal-large {
    max-height: 90vh;
}

.modal-small {
    max-width: 340px;
}

.modal-small .modal-body p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    text-align: center;
    padding: 8px 0;
}

.btn-danger {
    background: var(--danger);
    color: white;
    border: none;
}

.btn-danger:active {
    background: #c0392b;
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
}

.modal-header h3 {
    font-size: 17px;
    font-weight: 600;
}

.modal-close {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 22px;
    cursor: pointer;
    border-radius: 6px;
}

.modal-body {
    padding: 20px;
    overflow-y: auto;
    flex: 1;
}

.modal-footer {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    padding: 16px 20px;
    border-top: 1px solid var(--border);
}

/* ===== 表单 ===== */
.form-group {
    margin-bottom: 16px;
}

.form-group label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 6px;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
    font-family: inherit;
    transition: border-color 0.2s;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    border-color: var(--accent);
}

.form-group textarea {
    resize: vertical;
    min-height: 80px;
}

.model-preset-info {
    background: var(--accent-light);
    border-radius: var(--radius-sm);
    padding: 12px;
    margin-top: 8px;
}

.model-preset-info p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
}

.model-preset-info .hint {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 4px;
}

.model-version-desc {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 4px;
    padding-left: 2px;
}

/* ===== 加载动画 ===== */
.loading-spinner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 0;
    gap: 16px;
}

.spinner {
    width: 36px;
    height: 36px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ===== 工作流结果 ===== */
.wf-result-content {
    font-size: 14px;
    line-height: 1.8;
    color: var(--text-primary);
}

.wf-result-content h4 {
    font-size: 16px;
    margin: 12px 0 6px;
    color: var(--accent);
}

.wf-result-content ul {
    padding-left: 16px;
    margin: 6px 0;
}

.wf-result-content li {
    margin-bottom: 4px;
    color: var(--text-secondary);
}

.highlight {
    color: var(--accent);
    font-weight: 600;
}

/* ===== 批量推进 ===== */
.auto-write-progress {
    text-align: center;
    padding: 20px 0;
}

.progress-bar-container {
    width: 100%;
    height: 6px;
    background: var(--bg-input);
    border-radius: 3px;
    margin-bottom: 16px;
    overflow: hidden;
}

.progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #8b5cf6);
    border-radius: 3px;
    transition: width 0.5s ease;
}

.auto-write-report {
    text-align: center;
    padding: 20px 0;
}

.report-header {
    margin-bottom: 20px;
}

.report-header h3 {
    font-size: 20px;
    margin-top: 10px;
    color: var(--success);
}

.report-stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 16px;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-value {
    font-size: 36px;
    font-weight: 700;
    color: var(--accent);
}

.stat-label {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
}

.report-note {
    font-size: 13px;
    color: var(--text-muted);
}

/* ===== 错误提示 ===== */
.error-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 30px 0;
    color: var(--danger);
    text-align: center;
}

/* ===== 空状态 ===== */
.empty-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
}

.empty-state svg {
    margin-bottom: 12px;
}

.empty-state p {
    font-size: 14px;
    line-height: 1.6;
}

.empty-text {
    color: var(--text-muted);
    font-size: 13px;
    text-align: center;
    padding: 10px 0;
}

/* ===== Toast ===== */
.toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--bg-card);
    color: var(--text-primary);
    padding: 10px 24px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
    z-index: 300;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    pointer-events: none;
    opacity: 0;
}

.toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    /* 兜底：3秒后强制隐藏，防止 JS 定时器失效导致 toast 不消失 */
    animation: toastAutoHide 3.5s forwards;
}

@keyframes toastAutoHide {
    0%, 85% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(100px); }
}

/* ===== 滚动条 ===== */
::-webkit-scrollbar {
    width: 4px;
}

::-webkit-scrollbar-track {
    background: transparent;
}

::-webkit-scrollbar-thumb {
    background: var(--border-light);
    border-radius: 2px;
}

/* ===== 书籍摘要区 ===== */
.book-summary-collapsed {
    padding: 0;
    margin-bottom: 4px;
}

.summary-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    cursor: pointer;
    border: 1px solid var(--border);
    transition: background 0.2s;
}

.summary-bar:active {
    background: var(--bg-card-hover);
}

.summary-bar-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
}

.summary-book-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}

.summary-brief {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.summary-arrow {
    color: var(--text-muted);
    transition: transform 0.3s;
    flex-shrink: 0;
}

.book-summary-expanded {
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    padding: 16px;
    margin-bottom: 8px;
    border: 1px solid var(--border);
}

.summary-content {
    margin-bottom: 12px;
}

.summary-section {
    margin-bottom: 10px;
}

.summary-label {
    font-size: 11px;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 4px;
}

.summary-section p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
}

.summary-section span {
    font-size: 13px;
    color: var(--text-secondary);
}

.summary-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

/* ===== 阅读器容器 ===== */
.reader-container {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 16px;
    border: 1px solid var(--border);
    min-height: 200px;
    flex: 1;
    overflow-y: auto;
}

.reader-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
}

.reader-empty svg {
    margin-bottom: 12px;
}

.reader-empty p {
    margin-bottom: 16px;
    font-size: 14px;
}

.reader-chapter-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
}

.reader-body {
    font-size: 16px;
    line-height: 2;
    color: var(--text-primary);
    letter-spacing: 0.3px;
}

.reader-body p {
    text-indent: 2em;
    margin-bottom: 8px;
}

.reader-placeholder {
    color: var(--text-muted) !important;
    font-style: italic;
    text-align: center;
    padding: 30px 0;
}

/* ===== 底部反馈栏 ===== */
.reader-feedback-bar {
    position: sticky;
    bottom: 0;
    display: flex;
    gap: 8px;
    padding: 10px 16px;
    padding-bottom: calc(10px + var(--safe-bottom));
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
}

.feedback-input {
    flex: 1;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 13px;
    color: var(--text-primary);
    outline: none;
}

.feedback-input::placeholder {
    color: var(--text-muted);
    font-size: 12px;
}

.feedback-input:focus {
    border-color: var(--accent);
}

/* ===== 全屏阅读器 ===== */
.reader-full-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
}

.reader-progress {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
}

.reader-full-scroll {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
}

.reader-full-content {
    padding: 20px 18px;
    padding-bottom: 80px;
}

.reader-full-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    text-align: center;
}

.reader-full-body {
    font-size: 17px;
    line-height: 2.1;
    color: var(--text-primary);
    letter-spacing: 0.3px;
}

.reader-full-body p {
    text-indent: 2em;
    margin-bottom: 10px;
}

/* 章尾：自动下一章 */
.chapter-end {
    text-align: center;
    padding: 30px 18px 60px;
}

.chapter-end-divider {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 16px;
    letter-spacing: 2px;
}

.chapter-next-auto {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-light);
    border: 1px solid var(--accent);
    border-radius: 20px;
    padding: 10px 24px;
    font-size: 14px;
    color: var(--accent);
    cursor: pointer;
    transition: all 0.2s;
}

.chapter-next-auto:active {
    background: var(--accent);
    color: white;
}

/* 浮动AI按钮 */
.fab-ai {
    position: fixed;
    bottom: 100px;
    right: 20px;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    border: none;
    color: white;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 50;
    transition: transform 0.2s, box-shadow 0.2s;
}

.fab-ai:active {
    transform: scale(0.92);
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
}

/* 反馈弹窗 */
.feedback-popup {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-end;
}

.feedback-popup-mask {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
}

.feedback-popup-panel {
    position: relative;
    width: 100%;
    background: var(--bg-card);
    border-radius: 16px 16px 0 0;
    padding: 16px;
    padding-bottom: calc(16px + var(--safe-bottom));
    animation: slideUp 0.25s ease;
}

@keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}

.feedback-textarea {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px;
    font-size: 14px;
    color: var(--text-primary);
    resize: none;
    outline: none;
    font-family: inherit;
    margin-bottom: 12px;
}

.feedback-textarea:focus {
    border-color: var(--accent);
}

.feedback-textarea::placeholder {
    color: var(--text-muted);
}

.feedback-popup-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

/* ===== 章节菜单 ===== */
.chapter-menu-item {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s;
    gap: 12px;
}

.chapter-menu-item:active {
    background: var(--bg-card-hover);
}

.chapter-menu-item.active {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
}

.chapter-menu-order {
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-light);
    padding: 2px 8px;
    border-radius: 4px;
    flex-shrink: 0;
}

.chapter-menu-title {
    font-size: 14px;
    color: var(--text-primary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.chapter-menu-words {
    font-size: 11px;
    color: var(--text-muted);
    flex-shrink: 0;
}

/* ===== 创作规划页 ===== */
.plan-header {
    padding: 16px;
    text-align: center;
}

.plan-header h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--text-primary);
}

.plan-header p {
    font-size: 13px;
    color: var(--text-muted);
}

.plan-tabs {
    display: flex;
    padding: 0 16px;
    gap: 4px;
    margin-bottom: 12px;
}

.plan-tab {
    flex: 1;
    padding: 10px 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
}

.plan-tab.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
    font-weight: 600;
}

.plan-content {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
}

.plan-text {
    font-size: 14px;
    line-height: 1.8;
    color: var(--text-primary);
}

.plan-text p {
    margin-bottom: 8px;
}

.plan-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
}

.plan-empty p {
    font-size: 14px;
    margin-bottom: 4px;
}

.plan-empty .hint {
    font-size: 12px;
}

.plan-actions {
    padding: 12px 16px;
    padding-bottom: calc(12px + var(--safe-bottom));
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
}

/* ===== 灵墨对话页 ===== */
.brainstorm-page {
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    overflow: hidden !important;
    padding: 0 !important;
}

.bs-chat-container {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    -webkit-overflow-scrolling: touch;
}

.bs-msg {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    animation: fadeIn 0.3s ease;
}

.bs-ai {
    align-items: flex-start;
}

.bs-user {
    justify-content: flex-end;
}

.bs-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}

.bs-bubble {
    max-width: 80%;
    padding: 12px 16px;
    border-radius: 16px;
    font-size: 14px;
    line-height: 1.7;
    word-break: break-word;
}

.ai-bubble {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top-left-radius: 4px;
    color: var(--text-primary);
}

.user-bubble {
    background: var(--accent);
    color: white;
    border-top-right-radius: 4px;
}

.bs-thinking {
    color: var(--text-muted);
    font-style: italic;
    animation: pulse 1.5s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
}

.bs-input-bar {
    display: flex;
    gap: 8px;
    padding: 10px 12px;
    padding-bottom: calc(10px + var(--safe-bottom));
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
}

.bs-input {
    flex: 1;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 10px 18px;
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
}

.bs-input::placeholder {
    color: var(--text-muted);
}

.bs-input:focus {
    border-color: var(--accent);
}

.bs-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.15s;
}

.bs-send-btn:active {
    transform: scale(0.9);
}

/* 提取卡片 */
.bs-extract-card {
    background: linear-gradient(135deg, var(--accent-light), rgba(139, 92, 246, 0.1));
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 14px;
    margin: 12px 0;
    animation: fadeIn 0.4s ease;
}

.bs-extract-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    font-size: 14px;
    color: var(--text-primary);
}

.bs-extract-icon {
    font-size: 20px;
}

.bs-extract-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.bs-extract-row {
    display: flex;
    gap: 10px;
    font-size: 13px;
    line-height: 1.6;
}

.bs-extract-row span:first-child {
    color: var(--accent);
    font-weight: 600;
    min-width: 50px;
    flex-shrink: 0;
}

.bs-extract-row span:last-child {
    color: var(--text-secondary);
}

/* ===== 引导式创作助手 ===== */
.guide-container {
    display: flex;
    flex-direction: column;
    height: 100%;
}

.guide-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
}

.guide-bottom {
    padding: 12px 16px;
    padding-bottom: calc(12px + var(--safe-bottom));
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
}

.guide-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    margin-bottom: 12px;
}

.guide-card h3 {
    font-size: 16px;
    margin-bottom: 10px;
    color: var(--text-primary);
}

.guide-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 6px;
}

.guide-welcome {
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.guide-info {
    border-left: 3px solid var(--accent);
}

.guide-has-content {
    color: var(--success) !important;
    font-size: 12px !important;
}

.guide-no-content {
    color: var(--text-muted) !important;
    font-size: 12px !important;
}

.guide-warn {
    color: var(--warning) !important;
    font-size: 12px !important;
}

.guide-question {
    background: var(--accent-light);
    border-radius: var(--radius-sm);
    padding: 12px;
    margin: 12px 0;
}

.guide-question p {
    font-size: 14px;
    color: var(--text-primary);
}

.guide-hint {
    font-size: 12px !important;
    color: var(--text-muted) !important;
    margin-top: 4px !important;
}

.guide-input {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px;
    font-size: 14px;
    color: var(--text-primary);
    resize: vertical;
    outline: none;
    font-family: inherit;
    margin-bottom: 10px;
    min-height: 60px;
}

.guide-input:focus {
    border-color: var(--accent);
}

.guide-input::placeholder {
    color: var(--text-muted);
}

.guide-choices {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
}

.guide-choice-btn {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 13px;
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
}

.guide-choice-btn:active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
}

.guide-action-row {
    display: flex;
    gap: 10px;
}

.guide-action-row .btn {
    flex: 1;
}

.guide-thinking {
    text-align: center;
    padding: 30px 20px;
}

.guide-thinking p {
    margin-top: 16px;
    color: var(--text-secondary);
    font-size: 14px;
}

.guide-ai-questions {
    font-size: 14px;
    line-height: 1.8;
    color: var(--text-primary);
}

.guide-ai-questions strong {
    color: var(--accent);
}

.guide-sellpoint {
    font-size: 18px;
    font-weight: 600;
    color: var(--accent);
    padding: 16px;
    background: var(--accent-light);
    border-radius: var(--radius-sm);
    text-align: center;
    line-height: 1.6;
    margin: 10px 0;
}

.guide-structure {
    margin: 10px 0;
}

.guide-struct-item {
    padding: 8px 12px;
    background: var(--bg-input);
    border-radius: var(--radius-sm);
    margin-bottom: 6px;
    font-size: 13px;
    color: var(--text-secondary);
}

.guide-spec {
    font-size: 12px;
    line-height: 1.8;
    color: var(--text-secondary);
    background: var(--bg-input);
    padding: 12px;
    border-radius: var(--radius-sm);
    max-height: 300px;
    overflow-y: auto;
    font-family: monospace;
}

.guide-review {
    font-size: 13px;
    line-height: 1.8;
    color: var(--text-secondary);
    max-height: 350px;
    overflow-y: auto;
}

.guide-pass { color: var(--success); font-weight: 600; }
.guide-fail { color: var(--danger); font-weight: 600; }

.guide-result {
    font-size: 14px;
    line-height: 1.8;
    color: var(--text-primary);
    max-height: 400px;
    overflow-y: auto;
    background: var(--bg-input);
    padding: 12px;
    border-radius: var(--radius-sm);
}

.guide-success {
    text-align: center;
    border-color: var(--success);
}

.guide-success h3 {
    color: var(--success);
}

.guide-error {
    border-color: var(--danger);
}

.guide-error p {
    color: var(--danger);
}

.guide-hint-card {
    background: var(--bg-card-hover);
    border-style: dashed;
}

/* ===== 响应式 ===== */
@media (min-width: 600px) {
    #app {
        border-left: 1px solid var(--border);
        border-right: 1px solid var(--border);
    }

    .book-grid {
        grid-template-columns: 1fr 1fr;
    }
}
