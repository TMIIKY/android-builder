<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#1a1a2e">
    <title>AI小说生成器 - 灵墨</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div id="app">
        <!-- 顶部导航栏 -->
        <nav class="top-nav" id="topNav">
            <button class="nav-back" id="navBack" onclick="goBack()" style="display:none">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <h1 class="nav-title" id="navTitle">灵墨</h1>
            <button class="nav-action" id="navAction" onclick="openSettings()">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </button>
        </nav>

        <!-- 主内容区 -->
        <main class="main-content" id="mainContent">
            <!-- 灵墨对话页（默认首页 - AI引导式创作入口） -->
            <section class="page brainstorm-page active" id="brainstormPage">
                <div class="bs-chat-container" id="brainstormChat">
                    <!-- 动态填充 -->
                </div>
                <div class="bs-input-bar">
                    <input type="text" class="bs-input" id="brainstormInput" placeholder="说说你脑海中的故事..." onkeydown="if(event.key==='Enter')Brainstorm.send()">
                    <button class="bs-send-btn" onclick="Brainstorm.send()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    </button>
                </div>
            </section>

            <!-- 书架页面 -->
            <section class="page bookshelf-page" id="bookshelfPage">
                <div class="page-header">
                    <h2>我的书架</h2>
                    <button class="btn btn-primary" onclick="showCreateBookModal()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        新建书籍
                    </button>
                </div>
                <div class="book-grid" id="bookGrid">
                    <div class="empty-state">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        <p>还没有书籍，去「灵墨」聊聊你的想法吧</p>
                    </div>
                </div>
            </section>

            <!-- 书籍详情页（阅读模式） -->
            <section class="page book-detail-page" id="bookDetailPage">
                <!-- 书籍摘要区（默认收起） -->
                <div class="book-summary-collapsed" id="bookSummaryCollapsed">
                    <div class="summary-bar" onclick="toggleBookSummary()">
                        <div class="summary-bar-left">
                            <span class="summary-book-name" id="summaryBookName"></span>
                            <span class="summary-brief" id="summaryBrief"></span>
                        </div>
                        <svg class="summary-arrow" id="summaryArrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                </div>
                <div class="book-summary-expanded" id="bookSummaryExpanded" style="display:none">
                    <div class="summary-content" id="summaryContent"></div>
                    <div class="summary-actions">
                        <button class="btn btn-outline btn-sm" onclick="openBookMetaModal()">编辑信息</button>
                        <button class="btn btn-outline btn-sm" onclick="openPlanManager()">创作规划</button>
                        <button class="btn btn-outline btn-sm" onclick="viewMemory(currentBookId)">记忆状态</button>
                    </div>
                </div>

                <!-- 阅读器区域 -->
                <div class="reader-container" id="readerContainer">
                    <div class="reader-empty" id="readerEmpty">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        <p>暂无章节</p>
                        <button class="btn btn-primary btn-sm" onclick="showCreateChapterModal()">创建第一章</button>
                    </div>
                    <div class="reader-content" id="readerContent" style="display:none">
                        <h2 class="reader-chapter-title" id="readerChapterTitle"></h2>
                        <div class="reader-body" id="readerBody"></div>
                    </div>
                </div>

                <!-- 浮动AI按钮 -->
                <button class="fab-ai" id="fabAiDetail" onclick="toggleDetailFeedback()" style="display:none" title="告诉AI怎么改">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </button>
                <!-- 浮动反馈弹窗 -->
                <div class="feedback-popup" id="detailFeedbackPopup" style="display:none">
                    <div class="feedback-popup-mask" onclick="toggleDetailFeedback()"></div>
                    <div class="feedback-popup-panel">
                        <textarea class="feedback-textarea" id="feedbackInput" placeholder="告诉AI怎么改这段内容..." rows="2"></textarea>
                        <div class="feedback-popup-actions">
                            <button class="btn btn-outline btn-sm" onclick="toggleDetailFeedback()">取消</button>
                            <button class="btn btn-ai btn-sm" onclick="aiRevise()">改写</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 章节阅读页（翻页模式） -->
            <section class="page reader-page" id="readerPage">
                <div class="reader-full-header">
                    <button class="nav-back" onclick="closeReader()">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <span class="reader-progress" id="readerProgress"></span>
                    <button class="nav-action" onclick="openChapterMenu()">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                </div>
                <div class="reader-full-scroll" id="readerFullScroll">
                    <div class="reader-full-content" id="readerFullContent">
                        <h1 class="reader-full-title" id="readerFullTitle"></h1>
                        <div class="reader-full-body" id="readerFullBody"></div>
                    </div>
                    <!-- 章尾：自动加载下一章 -->
                    <div class="chapter-end" id="chapterEnd" style="display:none">
                        <div class="chapter-end-divider">— 本章完 —</div>
                        <button class="chapter-next-auto" id="chapterNextAuto" onclick="nextChapter()">
                            <span id="chapterNextLabel">下一章</span>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </button>
                    </div>
                </div>
                <!-- 浮动AI按钮 -->
                <button class="fab-ai" id="fabAi" onclick="toggleFeedbackBar()" title="告诉AI怎么改">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </button>
                <!-- 浮动反馈弹窗 -->
                <div class="feedback-popup" id="feedbackPopup" style="display:none">
                    <div class="feedback-popup-mask" onclick="toggleFeedbackBar()"></div>
                    <div class="feedback-popup-panel">
                        <textarea class="feedback-textarea" id="feedbackFullInput" placeholder="告诉AI怎么改这段内容..." rows="2"></textarea>
                        <div class="feedback-popup-actions">
                            <button class="btn btn-outline btn-sm" onclick="toggleFeedbackBar()">取消</button>
                            <button class="btn btn-ai btn-sm" onclick="aiReviseFull()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                改写
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 引导式创作助手页 -->
            <section class="page guide-page" id="guidePage">
                <div class="guide-container">
                    <div class="guide-scroll" id="guideContent">
                        <div class="guide-card">
                            <h3>加载中...</h3>
                        </div>
                    </div>
                    <div class="guide-bottom" id="guideActions"></div>
                </div>
            </section>

            <!-- 创作规划页（集中管理设定/大纲/章节规划） -->
            <section class="page plan-manager-page" id="planManagerPage">
                <div class="plan-header">
                    <h2>创作规划</h2>
                    <p>设定、大纲、章节规划集中管理</p>
                </div>
                <div class="plan-tabs">
                    <button class="plan-tab active" onclick="switchPlanTab('setting')">设定</button>
                    <button class="plan-tab" onclick="switchPlanTab('outline')">大纲</button>
                    <button class="plan-tab" onclick="switchPlanTab('chapter_plan')">章节规划</button>
                </div>
                <div class="plan-content" id="planContent">
                    <div class="plan-empty">
                        <p>选择上方标签查看或生成规划内容</p>
                    </div>
                </div>
                <div class="plan-actions">
                    <button class="btn btn-primary btn-full" id="planGenerateBtn" onclick="generatePlan()">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                        AI生成
                    </button>
                </div>
            </section>

            <!-- 设置页面 -->
            <section class="page settings-page" id="settingsPage">
                <div class="settings-section">
                    <h3>AI 模型配置</h3>
                    <div class="model-list" id="modelList"></div>
                    <button class="btn btn-outline btn-full" onclick="showAddModelModal()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        添加模型
                    </button>
                </div>
                <div class="settings-section">
                    <h3>当前使用模型</h3>
                    <select id="activeModel" class="model-select" onchange="switchModel(this.value)"></select>
                </div>

                <div class="settings-section">
                    <h3>导出作品</h3>
                    <p class="settings-hint">将小说导出为可阅读的电子书格式</p>
                    <div class="backup-actions">
                        <button class="btn btn-outline btn-full" onclick="showExportBookModal()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                            导出作品为 TXT / HTML
                        </button>
                    </div>
                </div>
                <div class="settings-section">
                    <h3>数据备份</h3>
                    <p class="settings-hint">导出/恢复全部书籍数据（JSON格式），用于换机迁移</p>
                    <div class="backup-actions">
                        <button class="btn btn-outline btn-full" onclick="exportData()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            导出备份文件
                        </button>
                        <button class="btn btn-outline btn-full" onclick="importData()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            从备份恢复
                        </button>
                        <button class="btn btn-outline btn-full" onclick="checkBackupStatus()" style="margin-top:8px">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            查看备份状态
                        </button>
                    </div>
                    <div class="backup-status" id="backupStatus" style="display:none; margin-top:12px; padding:12px; background:var(--bg-card); border-radius:8px; font-size:13px; color:var(--text-secondary);">
                    </div>
                </div>
            </section>

            <!-- 创作工作流页面 -->
            <section class="page workflow-page" id="workflowPage">
                <div class="workflow-header">
                    <h2>创作助手工作流</h2>
                    <p>基于开放小说创作助手，系统化辅助创作</p>
                </div>
                <div class="workflow-modules">
                    <div class="wf-module" onclick="startGuide('setting')">
                        <div class="wf-icon">🌍</div>
                        <div class="wf-info">
                            <h4>设定管理</h4>
                            <p>AI先问偏好，再生成世界观</p>
                        </div>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                    <div class="wf-module" onclick="startGuide('outline')">
                        <div class="wf-icon">📋</div>
                        <div class="wf-info">
                            <h4>大纲生成</h4>
                            <p>确认卖点→选择方向→生成大纲</p>
                        </div>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                    <div class="wf-module" onclick="startGuide('chapter')">
                        <div class="wf-icon">✍️</div>
                        <div class="wf-info">
                            <h4>章节写作</h4>
                            <p>规划→审阅→确认→生成正文</p>
                        </div>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                    <div class="wf-module" onclick="startGuide('review')">
                        <div class="wf-icon">🔍</div>
                        <div class="wf-info">
                            <h4>评审反馈</h4>
                            <p>五维度评审，选择改什么</p>
                        </div>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                    <div class="wf-module" onclick="runWorkflow('auto_write')">
                        <div class="wf-icon">🚀</div>
                        <div class="wf-info">
                            <h4>批量推进</h4>
                            <p>Spec→生成→评审→修订循环</p>
                        </div>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                </div>
            </section>
        </main>

        <!-- 底部导航 -->
        <nav class="bottom-nav">
            <button class="bottom-nav-item active" data-page="brainstorm" onclick="switchTab('brainstorm')">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>灵墨</span>
            </button>
            <button class="bottom-nav-item" data-page="bookshelf" onclick="switchTab('bookshelf')">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <span>书架</span>
            </button>
            <button class="bottom-nav-item" data-page="workflow" onclick="switchTab('workflow')">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <span>创作</span>
            </button>
            <button class="bottom-nav-item" data-page="settings" onclick="switchTab('settings')">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                <span>设置</span>
            </button>
        </nav>



        <!-- 模态框: 新建章节 -->
        <div class="modal-overlay" id="chapterModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>新建章节</h3>
                    <button class="modal-close" onclick="closeModal('chapterModal')">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>章节标题</label>
                        <input type="text" id="newChapterTitle" placeholder="输入章节标题">
                    </div>
                    <div class="form-group">
                        <label>引导提示词（告诉AI本章要写什么）</label>
                        <textarea id="newChapterPrompt" placeholder="例如：主角在拍卖会遇到强敌，意外获得神秘宝物..." rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('chapterModal')">取消</button>
                    <button class="btn btn-primary" onclick="createChapter()">创建并生成</button>
                </div>
            </div>
        </div>

        <!-- 模态框: 章节菜单（阅读时切换章节） -->
        <div class="modal-overlay" id="chapterMenuModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>目录</h3>
                    <button class="modal-close" onclick="closeModal('chapterMenuModal')">&times;</button>
                </div>
                <div class="modal-body" id="chapterMenuBody">
                </div>
            </div>
        </div>

        <!-- 模态框: 编辑书籍元信息 -->
        <div class="modal-overlay" id="bookMetaModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>编辑书籍信息</h3>
                    <button class="modal-close" onclick="closeModal('bookMetaModal')">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editBookId">
                    <div class="form-group">
                        <label>书名</label>
                        <input type="text" id="bookName" placeholder="输入书名">
                    </div>
                    <div class="form-group">
                        <label>类型</label>
                        <select id="bookGenre">
                            <option value="玄幻">玄幻</option><option value="仙侠">仙侠</option><option value="都市">都市</option>
                            <option value="科幻">科幻</option><option value="悬疑">悬疑</option><option value="言情">言情</option>
                            <option value="历史">历史</option><option value="游戏">游戏</option><option value="其他">其他</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>简介</label>
                        <textarea id="bookDesc" placeholder="输入书籍简介..." rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>世界观/初始设定</label>
                        <textarea id="bookSetting" placeholder="输入世界观设定、人物设定等..." rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('bookMetaModal')">取消</button>
                    <button class="btn btn-primary" onclick="saveBookMeta()">保存</button>
                </div>
            </div>
        </div>

        <!-- 模态框: 添加模型 -->
        <div class="modal-overlay" id="modelModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>添加AI模型</h3>
                    <button class="modal-close" onclick="closeModal('modelModal')">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>模型类型</label>
                        <select id="modelType" onchange="onModelTypeChange()">
                            <option value="deepseek">DeepSeek</option>
                            <option value="openai">OpenAI (GPT)</option>
                            <option value="claude">Claude (Anthropic)</option>
                            <option value="qwen">通义千问</option>
                            <option value="glm">智谱 GLM</option>
                            <option value="custom">自定义API</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>API 密钥</label>
                        <input type="password" id="modelKey" placeholder="输入API密钥">
                    </div>
                    <div class="form-group" id="modelVersionGroup">
                        <label>模型版本</label>
                        <select id="modelVersion" onchange="onModelVersionChange()"></select>
                        <p class="model-version-desc" id="modelVersionDesc"></p>
                    </div>
                    <div class="form-group" id="customEndpointGroup" style="display:none">
                        <label>API 端点</label>
                        <input type="text" id="modelEndpoint" placeholder="https://api.example.com/v1/chat/completions">
                    </div>
                    <div class="form-group" id="customModelNameGroup" style="display:none">
                        <label>模型名称</label>
                        <input type="text" id="modelName" placeholder="model-name">
                    </div>
                    <div class="model-preset-info" id="modelPresetInfo">
                        <p>💡 <strong>DeepSeek</strong>：默认端点 api.deepseek.com</p>
                        <p class="hint">密钥将加密存储在本地，不会上传到任何服务器</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('modelModal')">取消</button>
                    <button class="btn btn-primary" onclick="addModel()">确认接入</button>
                </div>
            </div>
        </div>

        <!-- 模态框: 批量推进 -->
        <div class="modal-overlay" id="autoWriteModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>批量推进写作</h3>
                    <button class="modal-close" onclick="closeModal('autoWriteModal')">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>推进章数</label>
                        <input type="number" id="autoChapterCount" value="3" min="1" max="10">
                    </div>
                    <div class="form-group">
                        <label>每章字数</label>
                        <select id="autoWordCount">
                            <option value="2000">~2000字</option>
                            <option value="3000" selected>~3000字</option>
                            <option value="5000">~5000字</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('autoWriteModal')">取消</button>
                    <button class="btn btn-primary" onclick="startAutoWrite()">开始推进</button>
                </div>
            </div>
        </div>

        <!-- 确认弹窗 -->
        <div class="modal-overlay" id="confirmModal">
            <div class="modal modal-small">
                <div class="modal-header">
                    <h3 id="confirmTitle">确认操作</h3>
                </div>
                <div class="modal-body">
                    <p id="confirmMessage"></p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('confirmModal')">取消</button>
                    <button class="btn btn-danger" onclick="doDeleteBook()">确认删除</button>
                </div>
            </div>
        </div>

        <div class="modal-overlay" id="exportBookModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>导出作品</h3>
                    <button class="modal-close" onclick="closeModal('exportBookModal')">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>选择书籍</label>
                        <select id="exportBookSelect"></select>
                    </div>
                    <div class="form-group">
                        <label>导出格式</label>
                        <div class="export-format-options">
                            <label class="export-format-option">
                                <input type="radio" name="exportFormat" value="txt" checked>
                                <span class="export-format-label">
                                    <strong>TXT</strong>
                                    <small>纯文本，兼容所有阅读器</small>
                                </span>
                            </label>
                            <label class="export-format-option">
                                <input type="radio" name="exportFormat" value="html">
                                <span class="export-format-label">
                                    <strong>HTML</strong>
                                    <small>带排版样式，浏览器打开即可阅读</small>
                                </span>
                            </label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="exportIncludePlans" checked>
                            包含设定/大纲/章节规划
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" onclick="closeModal('exportBookModal')">取消</button>
                    <button class="btn btn-primary" onclick="doExportBook()">导出</button>
                </div>
            </div>
        </div>

        <!-- 模态框: 工作流结果 -->
        <div class="modal-overlay" id="workflowResultModal">
            <div class="modal modal-large">
                <div class="modal-header">
                    <h3 id="wfResultTitle">创作结果</h3>
                    <button class="modal-close" onclick="closeModal('workflowResultModal')">&times;</button>
                </div>
                <div class="modal-body" id="wfResultBody">
                    <div class="loading-spinner">
                        <div class="spinner"></div>
                        <p>AI正在创作中...</p>
                    </div>
                </div>
                <div class="modal-footer" id="wfResultFooter" style="display:none">
                    <button class="btn btn-outline" onclick="closeModal('workflowResultModal')">关闭</button>
                    <button class="btn btn-primary" id="wfSaveBtn" onclick="saveWorkflowResult()">保存到书籍</button>
                </div>
            </div>
        </div>

        <!-- Toast 消息 -->
        <div class="toast" id="toast"></div>
    </div>

    <!-- Capacitor JS Bridge (必须在所有业务脚本之前加载) -->
    <script src="capacitor-core.js"></script>
    <script src="capacitor-filesystem.js"></script>
    <script src="android-bridge.js"></script>
    <script src="storage.js"></script>
    <script src="data-backup.js"></script>
    <script src="ai-service.js"></script>
    <script src="workflow.js"></script>
    <script src="guide.js"></script>
    <script src="brainstorm.js"></script>
    <script src="app.js"></script>
</body>
</html>
